# Copy this file to `.env` and fill in your actual values.
# `.env` is gitignored — your real key will never be committed.
#
# Required for any real (non-dry-run) pipeline execution.
ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# Optional: override the default config path. Most users don't need this.
# AGENTIC_DA_CONFIG=config/pipeline_config.yaml

