# Copy to .env and fill in. All app settings use the ANALYST_ prefix.

# REQUIRED: long random string; generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ANALYST_SECRET_KEY=change-me

# Set true when serving over HTTPS (recommended)
ANALYST_COOKIE_SECURE=false

# How the worker invokes the pipeline (see app/worker/pipeline_adapter.py for the CLI contract).
# The bundled adapter translates that contract to this repo's `python -m src.main`
# CLI; since this webapp lives inside the pipeline repo, the repo root is
# auto-detected and PIPELINE_REPO is not needed.
ANALYST_PIPELINE_CMD=python3 adapters/agentic_pipeline.py
#PIPELINE_REPO=            # only if the pipeline checkout lives elsewhere
#PIPELINE_PYTHON=          # pipeline interpreter; omit to use `uv run --project <repo>`
PIPELINE_BACKEND=foundry-dev   # anthropic | foundry | foundry-dev | azure-openai
#PIPELINE_EXTRA_ARGS=--dry-run  # token-free end-to-end plumbing test

ANALYST_MAX_CONCURRENT_RUNS=2
ANALYST_RUN_TIMEOUT_MINUTES=60
ANALYST_DEFAULT_TIMEZONE=America/Los_Angeles

# Credentials forwarded to the pipeline subprocess (worker only).
# Any SNOWFLAKE_* / ANTHROPIC_* / PIPELINE_* / AZURE_* vars are passed through.
# (The pipeline also loads the repo-root .env itself, so creds can live there instead.)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
ANTHROPIC_API_KEY=
